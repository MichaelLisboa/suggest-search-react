{
    "name": "react-suggest-as-you-type",
    "version": "0.1.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/MichaelLisboa/suggest-search-react.git"
    },
    "engines": {
        "node": ">=8.0.0"
    },
    "dependencies": {
        "@testing-library/jest-dom": "^4.2.4",
        "@testing-library/react": "^9.4.0",
        "@testing-library/user-event": "^7.2.1",
        "axios": "^0.19.2",
        "concurrently": "^4.1.2",
        "gh-pages": "^2.2.0",
        "nodemon": "^1.19.4",
        "react": "^16.12.0",
        "react-dom": "^16.12.0",
        "react-scripts": "3.3.1",
        "yes-https": "^1.0.0",
        "yup": "^0.27.0"
    },
    "scripts": {
        "predeploy": "npm run build",
        "deploy": "gh-pages -d build",
        "start": "node server.js",
        "build": "react-scripts build",
        "server": "nodemon server.js",
        "local": "concurrently \"npm run server\" \"react-scripts start\""
    },
    "eslintConfig": {
        "extends": "react-app"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "proxy": "http://localhost:5000"
}
